# ===========================================
# GPU.ai Environment Variables
# Copy to .env and fill in values
# ===========================================

# --- PostgreSQL ---
DATABASE_URL=postgresql://gpuai:gpuai@localhost:5432/gpuai

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Server ---
GPUCTL_PORT=9090

# --- Auth (Clerk) ---
CLERK_SECRET_KEY=

# --- Billing (Stripe) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Provider: RunPod ---
RUNPOD_API_KEY=

# --- Provider: E2E Networks ---
E2E_API_KEY=

# --- WireGuard Privacy Layer ---
WG_ENCRYPTION_KEY=           # 64 hex chars (32 bytes) for AES-256-GCM key encryption
WG_PROXY_ENDPOINT=           # Public IP:port of WireGuard proxy (e.g., 203.0.113.1:51820)
WG_PROXY_PUBLIC_KEY=         # Proxy server WireGuard public key (base64)
WG_INTERFACE_NAME=wg0        # WireGuard interface name (default: wg0)
WG_SUBNET=10.0.0.0/24

# --- Internal ---
INTERNAL_API_TOKEN=change-me  # used by cloud-init callback
