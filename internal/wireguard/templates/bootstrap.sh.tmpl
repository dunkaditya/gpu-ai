#!/bin/bash
# GPU.ai Instance Bootstrap Script
# Generated by gpuctl provisioning engine -- do not edit manually
# Compatible with both full VMs and Docker containers (e.g., RunPod pods)
set -euo pipefail

echo "[GPU.ai] Bootstrap starting..."

# ============================================================
# Detect environment: VM or container
# ============================================================
IS_CONTAINER=false
if [ -f /.dockerenv ] || grep -q 'docker\|containerd' /proc/1/cgroup 2>/dev/null; then
    IS_CONTAINER=true
    echo "[GPU.ai] Detected container environment"
else
    echo "[GPU.ai] Detected VM environment"
fi

# ============================================================
# 1. WireGuard Client Installation & Configuration
# ============================================================
WG_UP=false

install_wireguard_tools() {
    if command -v wg &>/dev/null; then
        echo "[GPU.ai] wireguard-tools already installed"
        return 0
    fi
    apt-get update -qq 2>/dev/null || true
    apt-get install -y -qq wireguard-tools 2>/dev/null || {
        echo "[GPU.ai] WARNING: Could not install wireguard-tools"
        return 1
    }
}

install_wireguard_tools

# Write WireGuard config
mkdir -p /etc/wireguard
cat > /etc/wireguard/wg0.conf << 'WGEOF'
[Interface]
PrivateKey = {{.InstancePrivateKey}}
Address = {{.InstanceAddress}}

[Peer]
PublicKey = {{.ProxyPublicKey}}
Endpoint = {{.ProxyEndpoint}}
AllowedIPs = {{.AllowedIPs}}
PersistentKeepalive = 25
WGEOF
chmod 600 /etc/wireguard/wg0.conf

# Try kernel WireGuard first (works on VMs, some privileged containers)
if modprobe wireguard 2>/dev/null; then
    echo "[GPU.ai] Kernel WireGuard module loaded"
    wg-quick up wg0 && WG_UP=true || echo "[GPU.ai] WARNING: wg-quick up failed with kernel module"
fi

# Fall back to wireguard-go userspace (works in unprivileged containers)
if [ "$WG_UP" = false ]; then
    echo "[GPU.ai] Trying wireguard-go userspace..."

    # Check if wireguard-go is available
    if ! command -v wireguard-go &>/dev/null; then
        # Try to download a pre-built binary
        WG_GO_URL="https://github.com/WireGuard/wireguard-go/releases/latest/download/wireguard-go-linux-amd64"
        curl -sL "$WG_GO_URL" -o /usr/local/bin/wireguard-go 2>/dev/null && \
            chmod +x /usr/local/bin/wireguard-go || {
            # Last resort: install Go and build from source
            if command -v go &>/dev/null || apt-get install -y -qq golang-go 2>/dev/null; then
                go install golang.zx2c4.com/wireguard-go@latest 2>/dev/null && \
                    cp "$(go env GOPATH)/bin/wireguard-go" /usr/local/bin/ || true
            fi
        }
    fi

    if command -v wireguard-go &>/dev/null; then
        export WG_QUICK_USERSPACE_IMPLEMENTATION=wireguard-go
        wg-quick up wg0 && WG_UP=true || echo "[GPU.ai] WARNING: wg-quick up failed with wireguard-go"
    else
        echo "[GPU.ai] WARNING: Could not install wireguard-go, tunnel unavailable"
    fi
fi

if [ "$WG_UP" = true ]; then
    echo "[GPU.ai] WireGuard tunnel is UP"
else
    echo "[GPU.ai] WARNING: WireGuard tunnel is DOWN -- SSH will still work via public IP"
fi

# ============================================================
# 2. SSH Keys + Security Hardening
# ============================================================
mkdir -p /root/.ssh
cat > /root/.ssh/authorized_keys << 'SSHEOF'
{{.SSHAuthorizedKeys}}
SSHEOF
chmod 700 /root/.ssh
chmod 600 /root/.ssh/authorized_keys

# Remove any provider-injected SSH keys (backdoor prevention)
sed -i '/^#.*provider\|^#.*runpod\|^#.*lambda/Id' /root/.ssh/authorized_keys 2>/dev/null || true

# Disable root password authentication
if [ -f /etc/ssh/sshd_config ]; then
    sed -i 's/^#*PermitRootLogin.*/PermitRootLogin prohibit-password/' /etc/ssh/sshd_config
    sed -i 's/^#*PasswordAuthentication.*/PasswordAuthentication no/' /etc/ssh/sshd_config
    # Restart SSH -- try systemctl first (VM), then service (container)
    systemctl restart sshd 2>/dev/null || service ssh restart 2>/dev/null || \
        /usr/sbin/sshd 2>/dev/null || true
fi

# Firewall: allow SSH only over WireGuard tunnel (skip if iptables unavailable in container)
if command -v iptables &>/dev/null && [ "$WG_UP" = true ]; then
    iptables -A INPUT -i wg0 -j ACCEPT
    iptables -A INPUT -p udp --dport 51820 -j ACCEPT
    iptables -A INPUT -i lo -j ACCEPT
    iptables -A INPUT -m state --state ESTABLISHED,RELATED -j ACCEPT
    iptables -A INPUT -j DROP
    echo "[GPU.ai] Firewall locked down to WireGuard tunnel"
else
    echo "[GPU.ai] Skipping firewall rules (iptables unavailable or tunnel down)"
fi

# ============================================================
# 3. Branded Hostname + MOTD
# ============================================================
# Set hostname (hostnamectl for VMs, direct write for containers)
hostnamectl set-hostname '{{.Hostname}}' 2>/dev/null || \
    echo '{{.Hostname}}' > /etc/hostname 2>/dev/null || true
echo '127.0.0.1 {{.Hostname}}' >> /etc/hosts

cat > /etc/motd << 'MOTDEOF'

  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚ēó   ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēó ‚Ėą‚Ėą‚ēó
 ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚ēĎ
 ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚Ėą‚ēó‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ
 ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚ēź‚ēĚ ‚Ėą‚Ėą‚ēĎ   ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĒ‚ēź‚ēź‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ
 ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ‚Ėą‚Ėą‚ēĎ     ‚ēö‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚Ėą‚ēĒ‚ēĚ  ‚Ėą‚Ėą‚ēĎ  ‚Ėą‚Ėą‚ēĎ‚Ėą‚Ėą‚ēĎ
  ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ ‚ēö‚ēź‚ēĚ      ‚ēö‚ēź‚ēź‚ēź‚ēź‚ēź‚ēĚ   ‚ēö‚ēź‚ēĚ  ‚ēö‚ēź‚ēĚ‚ēö‚ēź‚ēĚ

 Welcome to GPU.ai
 Instance: {{.Hostname}}
 Support: support@gpu.ai

MOTDEOF

# ============================================================
# 4. Provider Scrubbing
# ============================================================
# Block cloud metadata endpoint
if command -v iptables &>/dev/null; then
    iptables -A OUTPUT -d 169.254.169.254 -j DROP 2>/dev/null || true
fi

# Remove provider environment variables
for var in $(env | grep -iE '^(RUNPOD_|LAMBDA_|E2E_|VAST_|COREWEAVE_)' | cut -d= -f1); do
    unset "$var" 2>/dev/null || true
done

# Clean provider branding
rm -f /etc/update-motd.d/* 2>/dev/null || true
rm -f /etc/motd.d/* 2>/dev/null || true

# Remove provider CLI tools
for tool in runpodctl lambda-cloud e2ectl vastai; do
    rm -f "$(which "$tool" 2>/dev/null)" 2>/dev/null || true
done

# Stop provider agents (VM or container)
for svc in runpod-agent lambda-agent; do
    systemctl stop "$svc" 2>/dev/null || true
    systemctl disable "$svc" 2>/dev/null || true
    pkill -f "$svc" 2>/dev/null || true
done

# ============================================================
# 5. NVIDIA Driver Verification
# ============================================================
GPU_INFO=""
if command -v nvidia-smi &>/dev/null; then
    GPU_INFO=$(nvidia-smi --query-gpu=name,memory.total --format=csv,noheader 2>/dev/null || echo "nvidia-smi failed")
    echo "[GPU.ai] GPU detected: $GPU_INFO"
else
    echo "[GPU.ai] WARNING: nvidia-smi not found -- GPU may not be available"
    GPU_INFO="nvidia-smi not found"
fi

# ============================================================
# 6. Disable Unattended Upgrades (skip in containers)
# ============================================================
if [ "$IS_CONTAINER" = false ]; then
    systemctl stop unattended-upgrades 2>/dev/null || true
    systemctl disable unattended-upgrades 2>/dev/null || true
    apt-get remove -y unattended-upgrades 2>/dev/null || true
fi

cat > /etc/apt/apt.conf.d/99gpu-ai-no-auto-update << 'APTEOF'
APT::Periodic::Update-Package-Lists "0";
APT::Periodic::Unattended-Upgrade "0";
APT::Periodic::Download-Upgradeable-Packages "0";
APT::Periodic::AutocleanInterval "0";
APTEOF

# ============================================================
# 7. Ready Callback
# ============================================================
echo "[GPU.ai] Sending ready callback..."
curl -s -X POST '{{.CallbackURL}}' \
    -H 'Authorization: Bearer {{.InternalToken}}' \
    -H 'Content-Type: application/json' \
    -d "{\"gpu_info\": \"${GPU_INFO}\", \"wg_up\": \"${WG_UP}\"}" \
    --retry 3 --retry-delay 5 --max-time 30 || {
    echo "[GPU.ai] WARNING: Ready callback failed -- instance may not show as running"
}

echo "[GPU.ai] Bootstrap complete"
