#!/bin/bash
# GPU.ai Instance Bootstrap Script (FRP Tunneling)
# Generated by gpuctl provisioning engine -- do not edit manually
# Compatible with both full VMs and Docker containers (e.g., RunPod pods)
set -uo pipefail

echo "[GPU.ai] Bootstrap starting..."

# ============================================================
# Detect environment: VM or container
# ============================================================
IS_CONTAINER=false
if [ -f /.dockerenv ] || grep -q 'docker\|containerd' /proc/1/cgroup 2>/dev/null; then
    IS_CONTAINER=true
    echo "[GPU.ai] Detected container environment"
else
    echo "[GPU.ai] Detected VM environment"
fi

# ============================================================
# 1. FRP Client Installation
# ============================================================
FRP_VERSION="0.67.0"
echo "[GPU.ai] Downloading frpc v${FRP_VERSION}..."

# Try GitHub CDN first, then fall back to self-hosted if available
FRPC_DOWNLOADED=false

curl -sL --retry 3 --max-time 60 \
    "https://github.com/fatedier/frp/releases/download/v${FRP_VERSION}/frp_${FRP_VERSION}_linux_amd64.tar.gz" \
    -o /tmp/frp.tar.gz 2>/dev/null && \
    tar xzf /tmp/frp.tar.gz -C /tmp/ && \
    cp "/tmp/frp_${FRP_VERSION}_linux_amd64/frpc" /usr/local/bin/frpc && \
    chmod +x /usr/local/bin/frpc && \
    FRPC_DOWNLOADED=true && \
    echo "[GPU.ai] frpc downloaded from GitHub" || true

if [ "$FRPC_DOWNLOADED" = false ]; then
    echo "[GPU.ai] WARNING: GitHub download failed, frpc tunnel unavailable"
fi

rm -rf /tmp/frp.tar.gz /tmp/frp_* 2>/dev/null || true

# ============================================================
# 2. FRP Client Configuration
# ============================================================
if [ "$FRPC_DOWNLOADED" = true ]; then
    cat > /etc/frpc.toml << 'FRPEOF'
serverAddr = "{{.ProxyHost}}"
serverPort = {{.FRPServerPort}}
auth.method = "token"
auth.token = "{{.FRPToken}}"

[[proxies]]
name = "{{.InstanceID}}-ssh"
type = "tcp"
localIP = "127.0.0.1"
localPort = 22
remotePort = {{.RemotePort}}
FRPEOF

    echo "[GPU.ai] frpc config written to /etc/frpc.toml"
fi

# ============================================================
# 3. SSH Keys + Security Hardening
# ============================================================
mkdir -p /root/.ssh
cat > /root/.ssh/authorized_keys << 'SSHEOF'
{{.SSHAuthorizedKeys}}
SSHEOF
chmod 700 /root/.ssh
chmod 600 /root/.ssh/authorized_keys

# Remove any provider-injected SSH keys (backdoor prevention)
sed -i '/^#.*provider\|^#.*runpod\|^#.*lambda/Id' /root/.ssh/authorized_keys 2>/dev/null || true

# Disable root password authentication
if [ -f /etc/ssh/sshd_config ]; then
    sed -i 's/^#*PermitRootLogin.*/PermitRootLogin prohibit-password/' /etc/ssh/sshd_config
    sed -i 's/^#*PasswordAuthentication.*/PasswordAuthentication no/' /etc/ssh/sshd_config
    # Restart SSH -- try systemctl first (VM), then service (container)
    systemctl restart sshd 2>/dev/null || service ssh restart 2>/dev/null || \
        /usr/sbin/sshd 2>/dev/null || true
fi

# ============================================================
# 4. Start sshd and frpc
# ============================================================
# Ensure SSH host keys exist
ssh-keygen -A 2>/dev/null || true

# Start sshd if not already running
if ! pgrep -x sshd > /dev/null 2>&1; then
    /usr/sbin/sshd 2>/dev/null || true
fi

# Start frpc in background
if [ "$FRPC_DOWNLOADED" = true ]; then
    echo "[GPU.ai] Starting frpc..."
    nohup /usr/local/bin/frpc -c /etc/frpc.toml > /var/log/frpc.log 2>&1 &
    sleep 2
    if pgrep -x frpc > /dev/null 2>&1; then
        echo "[GPU.ai] frpc is running (tunnel active)"
    else
        echo "[GPU.ai] WARNING: frpc failed to start, check /var/log/frpc.log"
    fi
fi

# ============================================================
# 5. Branded Hostname + MOTD
# ============================================================
# Set hostname (hostnamectl for VMs, direct write for containers)
hostnamectl set-hostname '{{.Hostname}}' 2>/dev/null || \
    echo '{{.Hostname}}' > /etc/hostname 2>/dev/null || true
echo '127.0.0.1 {{.Hostname}}' >> /etc/hosts

cat > /etc/motd << 'MOTDEOF'

  ██████╗ ██████╗ ██╗   ██╗   █████╗ ██╗
 ██╔════╝ ██╔══██╗██║   ██║  ██╔══██╗██║
 ██║  ███╗██████╔╝██║   ██║  ███████║██║
 ██║   ██║██╔═══╝ ██║   ██║  ██╔══██║██║
 ╚██████╔╝██║     ╚██████╔╝  ██║  ██║██║
  ╚═════╝ ╚═╝      ╚═════╝   ╚═╝  ╚═╝╚═╝

 Welcome to GPU.ai
 Instance: {{.Hostname}}
 Support: support@gpu.ai

MOTDEOF

# ============================================================
# 6. Provider Scrubbing
# ============================================================
# Block cloud metadata endpoint
if command -v iptables &>/dev/null; then
    iptables -A OUTPUT -d 169.254.169.254 -j DROP 2>/dev/null || true
fi

# Remove provider environment variables
for var in $(env | grep -iE '^(RUNPOD_|LAMBDA_|E2E_|VAST_|COREWEAVE_)' | cut -d= -f1 || true); do
    unset "$var" 2>/dev/null || true
done

# Clean provider branding
rm -f /etc/update-motd.d/* 2>/dev/null || true
rm -f /etc/motd.d/* 2>/dev/null || true

# Remove provider CLI tools
for tool in runpodctl lambda-cloud e2ectl vastai; do
    rm -f "$(which "$tool" 2>/dev/null)" 2>/dev/null || true
done

# Stop provider agents (VM or container)
for svc in runpod-agent lambda-agent; do
    systemctl stop "$svc" 2>/dev/null || true
    systemctl disable "$svc" 2>/dev/null || true
    pkill -f "$svc" 2>/dev/null || true
done

# ============================================================
# 7. NVIDIA Driver Verification
# ============================================================
GPU_INFO=""
if command -v nvidia-smi &>/dev/null; then
    GPU_INFO=$(nvidia-smi --query-gpu=name,memory.total --format=csv,noheader 2>/dev/null || echo "nvidia-smi failed")
    echo "[GPU.ai] GPU detected: $GPU_INFO"
else
    echo "[GPU.ai] WARNING: nvidia-smi not found -- GPU may not be available"
    GPU_INFO="nvidia-smi not found"
fi

# ============================================================
# 8. Disable Unattended Upgrades (skip in containers)
# ============================================================
if [ "$IS_CONTAINER" = false ]; then
    systemctl stop unattended-upgrades 2>/dev/null || true
    systemctl disable unattended-upgrades 2>/dev/null || true
    apt-get remove -y unattended-upgrades 2>/dev/null || true
fi

cat > /etc/apt/apt.conf.d/99gpu-ai-no-auto-update << 'APTEOF'
APT::Periodic::Update-Package-Lists "0";
APT::Periodic::Unattended-Upgrade "0";
APT::Periodic::Download-Upgradeable-Packages "0";
APT::Periodic::AutocleanInterval "0";
APTEOF

# ============================================================
# 9. Ready Callback
# ============================================================
TUNNEL_UP="$FRPC_DOWNLOADED"
echo "[GPU.ai] Sending ready callback..."
curl -s -X POST '{{.CallbackURL}}' \
    -H 'Authorization: Bearer {{.InternalToken}}' \
    -H 'Content-Type: application/json' \
    -d "{\"gpu_info\": \"${GPU_INFO}\", \"tunnel_up\": \"${TUNNEL_UP}\"}" \
    --retry 3 --retry-delay 5 --max-time 30 || {
    echo "[GPU.ai] WARNING: Ready callback failed -- instance may not show as running"
}

echo "[GPU.ai] Bootstrap complete"

# ============================================================
# 10. Keep Container Alive
# ============================================================
# When running as dockerArgs in a container, this script IS the main process (PID 1).
# If it exits, the container stops. Run sshd in the background and use sleep infinity
# as the foreground process to keep PID 1 alive.
if [ "$IS_CONTAINER" = true ]; then
    echo "[GPU.ai] Container mode: starting sshd and keeping alive..."
    # Start sshd in background (not exec, so PID 1 survives if sshd fails)
    /usr/sbin/sshd -e 2>&1 || true
    # sleep infinity keeps PID 1 alive so the container never exits
    exec sleep infinity
fi
